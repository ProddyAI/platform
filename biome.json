{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**/*.js",
			"**/*.jsx",
			"**/*.ts",
			"**/*.tsx",
			"**/*.json",
			"**/*.mjs",
			"**/*.cjs",
			"!!**/node_modules",
			"!!**/.next",
			"!!**/dist",
			"!!**/out",
			"!!**/convex/_generated",
			"!!**/public"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 80
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useButtonType": "warn",
				"useSemanticElements": "warn",
				"noStaticElementInteractions": "off",
				"useKeyWithClickEvents": "warn",
				"noLabelWithoutControl": "warn",
				"noSvgWithoutTitle": "warn",
				"useAriaPropsSupportedByRole": "warn",
				"useFocusableInteractive": "warn",
				"useAriaPropsForRole": "warn"
			},
			"complexity": {
				"noExtraBooleanCast": "error",
				"noUselessCatch": "error"
			},
			"correctness": {
				"noConstAssign": "error",
				"noConstantCondition": "error",
				"noEmptyPattern": "error",
				"noGlobalObjectCalls": "error",
				"noInvalidConstructorSuper": "error",
				"noNonoctalDecimalEscape": "error",
				"noPrecisionLoss": "error",
				"noSelfAssign": "error",
				"noSetterReturn": "error",
				"noSwitchDeclarations": "error",
				"noUndeclaredVariables": "error",
				"noUnreachable": "error",
				"noUnreachableSuper": "error",
				"noUnsafeFinally": "error",
				"noUnsafeOptionalChaining": "error",
				"noUnusedLabels": "error",
				"noUnusedVariables": "off",
				"useIsNan": "error",
				"useValidForDirection": "error",
				"useExhaustiveDependencies": "warn",
				"noUnusedFunctionParameters": "warn",
				"useHookAtTopLevel": "error"
			},
			"style": {
				"useConst": "error",
				"useTemplate": "error",
				"noNonNullAssertion": "off"
			},
			"security": {
				"noDangerouslySetInnerHtml": "warn"
			},
			"suspicious": {
				"noAsyncPromiseExecutor": "warn",
				"noCatchAssign": "warn",
				"noClassAssign": "error",
				"noCompareNegZero": "warn",
				"noControlCharactersInRegex": "warn",
				"noDebugger": "warn",
				"noDoubleEquals": "off",
				"noDuplicateCase": "error",
				"noDuplicateClassMembers": "error",
				"noDuplicateObjectKeys": "error",
				"noDuplicateParameters": "error",
				"noEmptyBlockStatements": "off",
				"noExplicitAny": "off",
				"noExtraNonNullAssertion": "warn",
				"noFallthroughSwitchClause": "warn",
				"noFunctionAssign": "error",
				"noGlobalAssign": "error",
				"noImportAssign": "error",
				"noMisleadingCharacterClass": "warn",
				"noPrototypeBuiltins": "warn",
				"noRedeclare": "error",
				"noShadowRestrictedNames": "off",
				"noUnsafeNegation": "error",
				"noArrayIndexKey": "off",
				"useIterableCallbackReturn": "off",
				"noImplicitAnyLet": "off",
				"useGetterReturn": "error",
				"noVar": "warn",
				"noWith": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "es5",
			"semicolons": "always",
			"arrowParentheses": "always",
			"bracketSpacing": true,
			"lineEnding": "lf"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on",
				"useSortedAttributes": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/components/3pc/**"],
			"linter": {
				"rules": {
					"security": {
						"noDangerouslySetInnerHtml": "off"
					},
					"correctness": {
						"useExhaustiveDependencies": "off"
					}
				}
			}
		},
		{
			"includes": ["src/features/canvas/**"],
			"linter": {
				"rules": {
					"correctness": {
						"useExhaustiveDependencies": "off"
					}
				}
			}
		},
		{
			"includes": [
				"src/app/mockup/**",
				"src/features/reports/components/charts/**",
				"src/features/chats/components/**",
				"src/features/landing/**",
				"src/features/live/**",
				"src/components/ui/**",
				"src/components/AiNotemaker.tsx",
				"src/features/board/**",
				"src/features/canvas/**",
				"src/components/label-input.tsx",
				"src/components/member-selector.tsx"
			],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"noLabelWithoutControl": "off",
						"useFocusableInteractive": "off",
						"useAriaPropsForRole": "off",
						"useKeyWithClickEvents": "off"
					}
				}
			}
		}
	]
}
